{
  "name": "microsandbox-mcp",
  "version": "0.5.9",
  "description": "MCP server for microsandbox — manage microVM sandboxes from any AI agent",
  "type": "module",
  "bin": {
    "microsandbox-mcp": "bin/microsandbox-mcp.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "npm run build && node --test tests/*.test.mjs",
    "test:e2e": "npm run build && node tests/e2e-all-tools.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "microsandbox": "^0.5.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superradcompany/microsandbox-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "microsandbox",
    "sandbox",
    "microvm",
    "ai-agent"
  ]
}
